@{
    ViewData["Title"] = "Hakkında";
}

<section class="form-page">
  <div class="form-container">

    <a asp-controller="Home" asp-action="Index" class="back-link">
      <i class="bi bi-arrow-left"></i> Ana Sayfa
    </a>

    <div class="form-header">
      <span class="form-eyebrow">Açık Kaynak Proje</span>
      <h1 class="form-title">İhtiyaç Molası nedir?</h1>
      <p class="form-sub">
        Bir kişinin anlık küçük bir yardıma ihtiyaç duyduğu anlar için tasarlandı.
        Kayıt yok, şifre yok, kişisel veri yok.
      </p>
    </div>

    <div class="about-grid">

      <div class="about-block">
        <div class="ab-icon" style="--c:#00D4B4"><i class="bi bi-lightning-charge-fill"></i></div>
        <h3>Anlık & Hızlı</h3>
        <p>Talep oluşturmak 30 saniye sürer. Gönüllüler canlı akışta talebini görür, "Yapabilirim" der.</p>
      </div>

      <div class="about-block">
        <div class="ab-icon" style="--c:#FF5C6A"><i class="bi bi-incognito"></i></div>
        <h3>Anonim Kullanım</h3>
        <p>E-posta, şifre veya telefon numarası gerekmiyor. Rumuzunla ya da tamamen anonim yayınla.</p>
      </div>

      <div class="about-block">
        <div class="ab-icon" style="--c:#FFD166"><i class="bi bi-geo-alt-fill"></i></div>
        <h3>Mahalle Bazlı</h3>
        <p>Talepler mahalle filtresine göre listelenir. Gerçekten yardım edebilecek komşular seni bulur.</p>
      </div>

      <div class="about-block">
        <div class="ab-icon" style="--c:#818CF8"><i class="bi bi-github"></i></div>
        <h3>Açık Kaynak</h3>
        <p>Kaynak kod GitHub'da herkese açık. Kendi mahalleniz için kurabilir, katkı sağlayabilirsiniz.</p>
      </div>

    </div>

    <div class="about-tech">
      <h2 class="side-title"><i class="bi bi-cpu-fill"></i> Teknoloji Stack</h2>
      <div class="tech-list">
        <span class="tech-pill"><i class="bi bi-filetype-cs"></i> C# / ASP.NET MVC 8</span>
        <span class="tech-pill"><i class="bi bi-file-code"></i> Razor Pages (.cshtml)</span>
        <span class="tech-pill"><i class="bi bi-database-fill"></i> Microsoft SQL Server</span>
        <span class="tech-pill"><i class="bi bi-layers-fill"></i> Entity Framework Core (Database-First)</span>
        <span class="tech-pill"><i class="bi bi-palette-fill"></i> Vanilla CSS Design System</span>
        <span class="tech-pill"><i class="bi bi-person-fill"></i> Anonim / Session Bazlı Auth</span>
      </div>
    </div>
       
        <div class="about-author">
            <a href="https://github.com/furkhangul">
            <div class="vol-avatar large"><img src="https://avatars.githubusercontent.com/u/142796984?v=4" style="border:1px solid white; border-radius:100px;"  /></div>
      <div >
        <span class="vol-name" style="font-size:1rem">Furkan Gül</span>
        <span class="vol-time">Software Engeener</span>
                    <span class="vol-time"> </span>
                </a>
      </div>
      
    </div>

  </div>
</section>

<style>
.about-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 18px; margin-bottom: 32px;
}
.about-block {
  padding: 22px; border-radius: var(--r-xl);
  border: 1px solid var(--border); background: var(--surface);
  display: flex; flex-direction: column; gap: 10px;
}
.ab-icon {
  width: 44px; height: 44px; border-radius: 12px;
  background: color-mix(in srgb, var(--c) 14%, transparent);
  border: 1px solid color-mix(in srgb, var(--c) 30%, transparent);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem; color: var(--c);
}
.about-block h3 { font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 600; color: var(--white); }
.about-block p  { font-size: .87rem; color: var(--text-dim); line-height: 1.6; }

.about-tech {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-xl);
  padding: 24px; margin-bottom: 24px;
}
.tech-list { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 4px; }
.tech-pill {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 7px 14px; border-radius: var(--r-full);
  background: var(--bg-2); border: 1px solid var(--border-2);
  font-size: .83rem; color: var(--text-dim);
}
.tech-pill i { color: var(--teal); }

.about-author {
  display: flex; align-items: center; gap: 16px;
  padding: 20px; border-radius: var(--r-xl);
  border: 1px solid var(--border); background: var(--surface);
}
.vol-avatar.large { width: 52px; height: 52px; font-size: 1.3rem; }
.about-author .vol-time { display: block; }
</style>
