@model IhtiyacMolasi.ViewModels.VolunteerViewModel
@using IhtiyacMolasi.Models
@{
    ViewData["Title"] = "Talebi Üstlen";
    var req = Model.Request!;
}

<section class="form-page volunteer-page">
    <div class="form-container narrow">

        <a asp-controller="Request" asp-action="Detail" asp-route-id="@req.Id" class="back-link">
            <i class="bi bi-arrow-left"></i> Talebe Geri Dön
        </a>

        <!-- Talep özeti -->
        <div class="volunteer-request-preview" style="--bar-color:@req.Category!.ColorHex">
            <div class="vrp-cat">
                <i class="bi @req.Category.Icon"></i> @req.Category.Name
            </div>
            <h2 class="vrp-title">@req.Title</h2>
            <p class="vrp-desc">@req.Description</p>
            <div class="vrp-meta">
                <span><i class="bi bi-geo-alt"></i> @req.Neighborhood!.Name</span>
                <span><i class="bi bi-clock"></i> @req.TimeLeftDisplay</span>
                @if (req.UrgencyLevel == UrgencyLevel.ÇokAcil)
                { <span class="urg-badge urg-critical"><i class="bi bi-exclamation-circle-fill"></i> Çok Acil</span> }
                else if (req.UrgencyLevel == UrgencyLevel.Acil)
                { <span class="urg-badge urg-high"><i class="bi bi-lightning-fill"></i> Acil</span> }
            </div>
        </div>

        <!-- Form başlığı -->
        <div class="form-header centered">
            <div class="vol-icon-big"><i class="bi bi-hand-thumbs-up-fill"></i></div>
            <h1 class="form-title">Bu Talebi Üstleniyorum!</h1>
            <p class="form-sub">Adını veya rumuzunu belirt. Başka bir bilgiye ihtiyaç yok.</p>
        </div>

        <form asp-action="TakeRequest" method="post" class="modern-form" id="volForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="HelpRequestId" />

            <div class="form-section">
                <div class="field-group">
                    <label asp-for="VolunteerAlias" class="field-label">Adınız / Rumuzunuz *</label>
                    <input asp-for="VolunteerAlias" class="field-input large"
                           placeholder="Örn: AhmetK. ya da Komşu Bağcılar"
                           autofocus />
                    <span asp-validation-for="VolunteerAlias" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Note" class="field-label">Not (opsiyonel)</label>
                    <textarea asp-for="Note" class="field-textarea" rows="3"
                              placeholder="Örn: 20 dakika içinde yapabilirim, kapınıza geliyorum."
                              maxlength="500"></textarea>
                    <span asp-validation-for="Note" class="field-error"></span>
                </div>
            </div>

            <div class="form-submit-row">
                <p class="submit-note">
                    <i class="bi bi-heart-fill"></i>
                    Üstlendiğinde talep sahibi bilgilendirilecek. Gerçekten çok anlamlı!
                </p>
                <button type="submit" class="btn-submit volunteer-submit">
                    <i class="bi bi-hand-thumbs-up-fill"></i> Üstleniyorum!
                </button>
            </div>
        </form>

    </div>
</section>
